<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:foreground="?attr/selectableItemBackground"
        android:background="@drawable/item_file_bg"
        android:padding="8dp">

    <ImageView
            android:id="@+id/file_icon"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:paddingEnd="5dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    <TextView
            android:id="@+id/file_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="name"
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurface"
            android:singleLine="true"
            android:ellipsize="middle"
            android:maxLines="1"
            app:layout_constraintStart_toEndOf="@id/file_icon"
            app:layout_constraintTop_toTopOf="@id/file_icon"
            app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
            android:id="@+id/file_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/radius_bg"
            android:text="size"
            android:textSize="11sp"
            android:lineHeight="16sp"
            android:paddingVertical="4dp"
            android:paddingHorizontal="6dp"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:layout_constraintStart_toEndOf="@id/file_icon"
            app:layout_constraintBottom_toBottomOf="@id/file_icon"/>

    <TextView
            android:id="@+id/file_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="time"
            android:background="@drawable/radius_bg"
            android:textSize="11sp"
            android:lineHeight="16sp"
            android:paddingVertical="4dp"
            android:paddingHorizontal="6dp"
            android:layout_marginLeft="4dp"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:layout_constraintStart_toEndOf="@id/file_info"
            app:layout_constraintBottom_toBottomOf="@id/file_icon"/>

</androidx.constraintlayout.widget.ConstraintLayout>
